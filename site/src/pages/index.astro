---
import "../styles/custom.css";

const GITHUB_URL = "https://github.com/Prograde-Solutions/orp";
const site = Astro.site ?? new URL("https://orp.dev");
const base = import.meta.env.BASE_URL; // includes trailing slash
const href = (p) => base + p.replace(/^\//, "");
const canonical = new URL(base, site).href;
const ogImage = new URL(href("/og/orp-og.png"), site).href;
const title = "ORP: The structurally blind rendezvous server";
const description =
  "ORP is a device-first messaging protocol whose rendezvous server cannot read contents, keys, or signaling. An enforced invariant, not a logging policy.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    name: "ORP",
    description,
    url: canonical,
    codeRepository: GITHUB_URL,
    programmingLanguage: "TypeScript",
    author: { "@type": "Organization", name: "Prograde Solutions" },
    license: "https://www.apache.org/licenses/LICENSE-2.0",
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "ORP",
    url: site.href,
    description,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={href("/favicon.svg")} type="image/svg+xml" />
    <meta name="theme-color" content="#0E1726" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="ORP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="ORP. The rendezvous server is structurally blind."
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link
      rel="preload"
      as="image"
      href={href("/favicon.svg")}
      type="image/svg+xml"
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
      is:inline
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <div class="bg-aurora" aria-hidden="true"></div>

    <header class="site-header">
      <a class="brand" href={base} aria-label="ORP home">
        <svg
          class="brand-mark"
          viewBox="0 0 168 40"
          role="img"
          aria-hidden="true"
        >
          <g transform="translate(20 20)">
            <ellipse
              cx="0"
              cy="0"
              rx="18"
              ry="11"
              transform="rotate(-20)"
              fill="none"
              stroke="#2F74E6"
              stroke-width="2.4"></ellipse>
            <g stroke="#ffffff" stroke-width="1.6" stroke-linecap="round">
              <line x1="-7" y1="2.4" x2="6.5" y2="-2.4"></line>
              <line x1="-4.5" y1="-0.6" x2="-2.5" y2="2"></line>
              <line x1="-1.5" y1="-1.6" x2="0.5" y2="1"></line>
              <line x1="1.5" y1="-2.6" x2="3.5" y2="0"></line>
            </g>
          </g>
          <text
            x="46"
            y="28"
            font-family="Georgia, serif"
            font-size="26"
            font-weight="700"
            letter-spacing="1.5"
            fill="#ffffff">ORP</text
          >
        </svg>
      </a>
      <nav class="site-nav" aria-label="Primary">
        <a href={href("/docs/overview/")}>Docs</a>
        <a href={href("/compare/")}>Why blind</a>
        <a class="nav-cta" href={GITHUB_URL} rel="noopener">GitHub</a>
      </nav>
    </header>

    <main id="main">
      <section class="hero">
        <p class="eyebrow">Open Rendezvous Protocol</p>
        <h1>The rendezvous server is <span class="grad">structurally blind.</span></h1>
        <p class="lede">
          An enforced invariant, not a logging policy. ORP is a device-first
          messaging protocol whose rendezvous server is structurally unable to
          read message contents, keys, or unsealed signaling.
        </p>
        <div class="cta-row">
          <a class="btn btn-primary" href={href("/docs/overview/")}
            >Read the docs</a
          >
          <a class="btn btn-ghost" href={GITHUB_URL} rel="noopener"
            >View on GitHub</a
          >
        </div>
      </section>

      <!-- Interactive Three.js scene: the blind broker -->
      <section class="scene-section" aria-labelledby="scene-h">
        <div class="scene-head">
          <h2 id="scene-h">Watch a rendezvous happen</h2>
          <p class="section-lede">
            Two devices share one key bound to one target. They relay sealed
            payloads through the board. Drag to orbit — then flip to
            <em>the board's view</em> and watch everything it cannot read
            collapse to opaque tags.
          </p>
        </div>

        <div class="scene-wrap">
          <div id="orp-scene" class="scene-canvas" role="img"
            aria-label="3D animation of two devices exchanging sealed payloads through a blind rendezvous board.">
            <!-- SVG fallback, hidden once WebGL initializes -->
            <svg
              id="scene-fallback"
              class="diagram"
              viewBox="0 0 720 240"
              role="img"
              aria-labelledby="diagram-title diagram-desc"
            >
              <title id="diagram-title">ORP blind broker data flow</title>
              <desc id="diagram-desc"
                >Device A and Device B each connect to the board. They send
                opaque presence tags and sealed offer and answer payloads. The
                board routes by tag but cannot read the sealed contents.</desc
              >
              <g fill="none" stroke="#2f74e6" stroke-width="2">
                <rect x="20" y="90" width="150" height="60" rx="10"></rect>
                <rect x="285" y="90" width="150" height="60" rx="10"></rect>
                <rect x="550" y="90" width="150" height="60" rx="10"></rect>
              </g>
              <g fill="#f4f7fc" font-family="Georgia, serif" font-size="18"
                text-anchor="middle">
                <text x="95" y="125">Device A</text>
                <text x="360" y="118">Blind board</text>
                <text x="625" y="125">Device B</text>
              </g>
              <g fill="#8f9bb0" font-family="sans-serif" font-size="12"
                text-anchor="middle">
                <text x="360" y="138">routes opaque tags</text>
                <text x="227" y="80">sealed offer</text>
                <text x="493" y="80">sealed answer</text>
              </g>
              <g stroke="#5b6678" stroke-width="2" marker-end="url(#arrow)">
                <line x1="170" y1="120" x2="283" y2="120"></line>
                <line x1="435" y1="120" x2="548" y2="120"></line>
              </g>
              <defs>
                <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5"
                  markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                  <path d="M0,0 L10,5 L0,10 z" fill="#5b6678"></path>
                </marker>
              </defs>
            </svg>
          </div>

          <!-- HUD overlay -->
          <div class="scene-hud" data-hud hidden>
            <div class="phase-track" role="tablist" aria-label="Rendezvous phases">
              <button class="phase-chip" data-phase="0" role="tab">KEY</button>
              <button class="phase-chip" data-phase="1" role="tab">OFFER</button>
              <button class="phase-chip" data-phase="2" role="tab">ANSWER</button>
              <button class="phase-chip" data-phase="3" role="tab">CONNECTED</button>
            </div>
            <p class="phase-caption" data-caption aria-live="polite"></p>
            <button class="board-toggle" data-board-toggle aria-pressed="false">
              <span class="dot"></span>
              <span class="toggle-text">See the board's view</span>
            </button>
          </div>
        </div>

        <p class="scene-note" data-board-note hidden>
          In the board's view, device identities reduce to opaque tags and every
          payload reads <code>SEALED</code>. The only thing the board reads is
          the <code>frame_kind</code> routing tag — exactly the
          <a href={href("/docs/blindness/")}>collision-table</a> observables, nothing more.
        </p>
      </section>

      <section class="problem reveal" aria-labelledby="problem-h">
        <h2 id="problem-h">Why signaling servers still see too much</h2>
        <div class="cards">
          <article class="card">
            <span class="card-num">01</span>
            <h3>The server still sees</h3>
            <p>
              A conventional signaling server reads the SDP, the keys exchanged
              through it, and who is talking to whom. End-to-end encryption of
              the call does not hide the rendezvous.
            </p>
          </article>
          <article class="card">
            <span class="card-num">02</span>
            <h3>Trust is a policy</h3>
            <p>
              No-log promises are operational policy. They can be changed,
              compelled, or quietly broken, and a user cannot tell from the
              outside that they hold.
            </p>
          </article>
          <article class="card">
            <span class="card-num">03</span>
            <h3>You cannot verify</h3>
            <p>
              There is usually no way for a client to prove the server did not
              retain metadata. The guarantee lives in the operator's conscience,
              not in the wire format.
            </p>
          </article>
        </div>
      </section>

      <section class="proof reveal" aria-labelledby="proof-h">
        <h2 id="proof-h">The proof is in the test suite</h2>
        <div class="cards">
          <article class="card">
            <h3>Adversarial tests</h3>
            <p>
              The suite is written to attack the invariant, with a per-test note
              of exactly what each one proves.
            </p>
          </article>
          <article class="card">
            <h3>Board-view scan</h3>
            <p>
              Asserts that everything the board can observe is limited to opaque
              tags and sealed payloads it cannot open.
            </p>
          </article>
          <article class="card">
            <h3>Wire-byte scan</h3>
            <p>
              Inspects raw datagram bytes on the wire to confirm no plaintext
              contents, keys, or unsealed signaling leak.
            </p>
          </article>
        </div>
        <p class="proof-note">
          TODO: confirm the test count and scan names against the repo (see
          OPEN-QUESTIONS.md).
        </p>
      </section>

      <section class="tradeoffs reveal" aria-labelledby="tradeoffs-h">
        <h2 id="tradeoffs-h">Stated trade-offs, up front</h2>
        <ul class="tradeoff-list">
          <li>
            <strong>No forward secrecy.</strong> The inner message layer is
            static, so a key compromise can expose past sealed payloads.
          </li>
          <li>
            <strong>The social graph is visible.</strong> The board can see that
            two endpoints meet, even though it cannot read what they exchange.
            This is not 100% anonymity, and we do not claim it.
          </li>
          <li>
            <strong>Replay and linkability bounds.</strong> Presence tags carry
            documented replay and linkability limits, with scoped mitigations
            rather than absolute guarantees.
          </li>
        </ul>
        <a class="inline-link" href={href("/docs/threat-model/")}
          >Read the full threat model →</a
        >
      </section>

      <section class="final-cta reveal" aria-labelledby="final-h">
        <h2 id="final-h">Read the spec, run the tests, see for yourself.</h2>
        <div class="cta-row">
          <a class="btn btn-primary" href={href("/docs/overview/")}
            >Read the docs</a
          >
          <a class="btn btn-ghost" href={GITHUB_URL} rel="noopener"
            >View on GitHub</a
          >
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>
        ORP, the Open Rendezvous Protocol. Core, client, spec, and tests under
        Apache-2.0; the board under AGPL-3.0.
      </p>
      <nav aria-label="Footer">
        <a href={href("/docs/overview/")}>Docs</a>
        <a href={href("/docs/faq/")}>FAQ</a>
        <a href={GITHUB_URL} rel="noopener">GitHub</a>
      </nav>
    </footer>

    <script>
      import { initOrpScene } from "../scripts/orp-scene.js";

      const PHASES = [
        {
          caption:
            "Both devices already hold one shared key bound to one target. They announce presence as opaque tags.",
        },
        {
          caption:
            "Device A's WebRTC offer (SDP/ICE) is sealed, then relayed through the board. The board forwards bytes it cannot open.",
        },
        {
          caption:
            "Device B seals its answer and sends it back. Same blind relay: the board routes on the tag, never the contents.",
        },
        {
          caption:
            "The peers open a direct channel. The board brokered the meeting and is now blind to the conversation entirely.",
        },
      ];

      const container = document.getElementById("orp-scene");
      const fallback = document.getElementById("scene-fallback");
      const hud = document.querySelector("[data-hud]");
      const caption = document.querySelector("[data-caption]");
      const boardToggle = document.querySelector("[data-board-toggle]");
      const boardNote = document.querySelector("[data-board-note]");
      const chips = Array.from(document.querySelectorAll(".phase-chip"));

      let scene = null;
      try {
        scene = initOrpScene(container, {
          onPhase(i) {
            chips.forEach((c, idx) =>
              c.setAttribute("aria-selected", idx === i ? "true" : "false"),
            );
            if (caption) caption.textContent = PHASES[i]?.caption ?? "";
          },
          onBoardView(on) {
            boardToggle?.setAttribute("aria-pressed", on ? "true" : "false");
            const t = boardToggle?.querySelector(".toggle-text");
            if (t) t.textContent = on ? "Showing the board's view" : "See the board's view";
            if (boardNote) boardNote.hidden = !on;
            hud?.classList.toggle("is-board", on);
          },
        });
      } catch (e) {
        scene = null;
      }

      if (scene) {
        fallback?.setAttribute("hidden", "");
        hud?.removeAttribute("hidden");
        chips.forEach((chip) =>
          chip.addEventListener("click", () =>
            scene.goToPhase(Number(chip.dataset.phase)),
          ),
        );
        boardToggle?.addEventListener("click", () =>
          scene.setBoardView(!scene.isBoardView()),
        );
      }

      // Scroll reveal for sections.
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const reveals = document.querySelectorAll(".reveal");
      if (reduce || !("IntersectionObserver" in window)) {
        reveals.forEach((el) => el.classList.add("in"));
      } else {
        const obs = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("in");
                obs.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        reveals.forEach((el) => obs.observe(el));
      }
    </script>

    <style>
      :global(html) {
        scroll-behavior: smooth;
      }
      :global(body) {
        margin: 0;
        background: var(--orp-bg-dark);
        color: #e3e9f2;
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial,
          sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      .bg-aurora {
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background:
          radial-gradient(
            60rem 40rem at 15% -10%,
            rgba(47, 116, 230, 0.18),
            transparent 60%
          ),
          radial-gradient(
            50rem 40rem at 100% 0%,
            rgba(56, 224, 208, 0.1),
            transparent 55%
          ),
          radial-gradient(
            40rem 40rem at 50% 120%,
            rgba(167, 139, 250, 0.1),
            transparent 60%
          );
      }
      .skip-link {
        position: absolute;
        left: -999px;
        top: 0;
        background: #2f74e6;
        color: #fff;
        padding: 0.5rem 1rem;
        z-index: 10;
      }
      .skip-link:focus {
        left: 0;
      }
      a {
        color: #9cc1f5;
      }
      h1,
      h2,
      h3 {
        font-family: var(--orp-serif);
        color: #f4f7fc;
        line-height: 1.15;
      }
      .grad {
        background: linear-gradient(100deg, #2f74e6 0%, #38e0d0 55%, #a78bfa 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .site-header {
        position: sticky;
        top: 0;
        z-index: 5;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.9rem 1.5rem;
        backdrop-filter: blur(10px);
        background: rgba(14, 23, 38, 0.6);
        border-bottom: 1px solid rgba(24, 36, 58, 0.8);
      }
      .site-header > * {
        max-width: 1080px;
      }
      .brand-mark {
        width: 132px;
        height: 32px;
        display: block;
      }
      .site-nav {
        display: flex;
        align-items: center;
      }
      .site-nav a {
        color: #c2cad8;
        text-decoration: none;
        margin-left: 1.5rem;
        font-size: 0.95rem;
      }
      .site-nav a:hover,
      .site-nav a:focus {
        color: #fff;
      }
      .nav-cta {
        border: 1px solid #2a3548;
        border-radius: 8px;
        padding: 0.4rem 0.9rem;
      }
      .nav-cta:hover {
        border-color: #2f74e6;
      }
      main {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      .hero {
        padding: 5rem 0 2.5rem;
        max-width: 820px;
      }
      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.8rem;
        color: #8fb4f2;
        margin: 0 0 1rem;
      }
      .hero h1 {
        font-size: clamp(2.4rem, 6.5vw, 4.2rem);
        margin: 0 0 1.25rem;
        letter-spacing: -0.5px;
      }
      .lede {
        font-size: 1.25rem;
        color: #c2cad8;
        margin: 0 0 2rem;
      }
      .section-lede {
        color: #c2cad8;
        max-width: 680px;
      }
      .cta-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .btn {
        display: inline-block;
        padding: 0.8rem 1.5rem;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        transition:
          transform 0.15s ease,
          box-shadow 0.2s ease,
          background 0.2s ease;
      }
      .btn-primary {
        background: linear-gradient(135deg, #2f74e6, #0e62cc);
        color: #fff;
        box-shadow: 0 8px 24px -10px rgba(47, 116, 230, 0.7);
      }
      .btn-primary:hover,
      .btn-primary:focus {
        transform: translateY(-2px);
        box-shadow: 0 12px 30px -10px rgba(47, 116, 230, 0.85);
      }
      .btn-ghost {
        border: 1px solid #2a3548;
        color: #e3e9f2;
      }
      .btn-ghost:hover,
      .btn-ghost:focus {
        border-color: #2f74e6;
        transform: translateY(-2px);
      }
      section {
        padding: 3rem 0;
        border-top: 1px solid #18243a;
      }
      .scene-section {
        border-top: none;
      }
      section h2 {
        font-size: clamp(1.6rem, 3vw, 2.3rem);
        margin: 0 0 0.5rem;
      }

      /* ---- Scene ---- */
      .scene-head {
        max-width: 720px;
        margin-bottom: 1.5rem;
      }
      .scene-wrap {
        position: relative;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid #1d2c46;
        background:
          radial-gradient(120% 120% at 50% 0%, #101d33 0%, #0a1322 70%);
        box-shadow:
          0 30px 80px -40px rgba(0, 0, 0, 0.8),
          inset 0 1px 0 rgba(255, 255, 255, 0.04);
      }
      .scene-canvas {
        width: 100%;
        height: clamp(380px, 58vh, 560px);
        display: grid;
        place-items: center;
      }
      .scene-canvas :global(canvas) {
        width: 100% !important;
        height: 100% !important;
      }
      .diagram {
        width: 100%;
        max-width: 620px;
        height: auto;
        padding: 1.5rem;
      }
      .scene-hud {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        padding: 1rem 1.25rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        background: linear-gradient(
          to top,
          rgba(8, 13, 22, 0.92),
          rgba(8, 13, 22, 0)
        );
        pointer-events: none;
      }
      .scene-hud > * {
        pointer-events: auto;
      }
      .phase-track {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
      }
      .phase-chip {
        font: inherit;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        color: #8f9bb0;
        background: rgba(18, 28, 46, 0.8);
        border: 1px solid #243450;
        border-radius: 999px;
        padding: 0.3rem 0.85rem;
        cursor: pointer;
        transition: all 0.18s ease;
      }
      .phase-chip:hover {
        color: #e3e9f2;
        border-color: #2f74e6;
      }
      .phase-chip[aria-selected="true"] {
        color: #fff;
        background: linear-gradient(135deg, #2f74e6, #0e62cc);
        border-color: transparent;
        box-shadow: 0 4px 16px -6px rgba(47, 116, 230, 0.8);
      }
      .phase-caption {
        margin: 0;
        font-size: 0.95rem;
        color: #cbd5e6;
        max-width: 640px;
        min-height: 2.8em;
      }
      .board-toggle {
        align-self: flex-start;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font: inherit;
        font-size: 0.88rem;
        font-weight: 600;
        color: #e3e9f2;
        background: rgba(18, 28, 46, 0.85);
        border: 1px solid #2a3a58;
        border-radius: 10px;
        padding: 0.5rem 0.95rem;
        cursor: pointer;
        transition: all 0.18s ease;
      }
      .board-toggle .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #5b6678;
        box-shadow: 0 0 0 0 rgba(56, 224, 208, 0.5);
        transition: all 0.2s ease;
      }
      .board-toggle[aria-pressed="true"] {
        border-color: #38e0d0;
        color: #aef6ec;
      }
      .board-toggle[aria-pressed="true"] .dot {
        background: #38e0d0;
        box-shadow: 0 0 12px 2px rgba(56, 224, 208, 0.6);
      }
      .board-toggle:hover {
        border-color: #38e0d0;
      }
      .scene-note {
        margin: 1rem 0 0;
        font-size: 0.9rem;
        color: #9aa6bd;
        max-width: 680px;
      }
      .scene-note code {
        background: #14233c;
        border-radius: 5px;
        padding: 0.1rem 0.35rem;
        font-size: 0.85em;
        color: #aef6ec;
      }

      /* ---- Cards ---- */
      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.25rem;
        margin-top: 1.75rem;
      }
      .card {
        position: relative;
        background: linear-gradient(180deg, #101b2e 0%, #0c1422 100%);
        border: 1px solid #18243a;
        border-radius: 14px;
        padding: 1.6rem;
        transition:
          transform 0.2s ease,
          border-color 0.2s ease,
          box-shadow 0.2s ease;
      }
      .card:hover {
        transform: translateY(-4px);
        border-color: #2a4673;
        box-shadow: 0 18px 40px -24px rgba(47, 116, 230, 0.6);
      }
      .card-num {
        font-family: var(--orp-serif);
        font-size: 0.85rem;
        color: #2f74e6;
        opacity: 0.7;
        letter-spacing: 1px;
      }
      .card h3 {
        margin: 0.4rem 0 0.6rem;
        font-size: 1.2rem;
        color: #cfe0fb;
      }
      .card p {
        margin: 0;
        color: #c2cad8;
        font-size: 0.97rem;
      }
      .proof-note {
        margin-top: 1.5rem;
        font-size: 0.85rem;
        color: #8f9bb0;
      }
      .tradeoff-list {
        list-style: none;
        padding: 0;
        margin: 1.5rem 0;
        display: grid;
        gap: 1rem;
        max-width: 760px;
      }
      .tradeoff-list li {
        padding: 0.6rem 0 0.6rem 1.25rem;
        border-left: 3px solid #2f74e6;
        color: #c2cad8;
      }
      .tradeoff-list strong {
        color: #f4f7fc;
      }
      .inline-link {
        font-weight: 600;
        text-decoration: none;
      }
      .final-cta {
        text-align: center;
        padding: 4.5rem 0;
      }
      .final-cta .cta-row {
        justify-content: center;
        margin-top: 1.5rem;
      }

      /* ---- Reveal animation ---- */
      .reveal {
        opacity: 0;
        transform: translateY(24px);
        transition:
          opacity 0.6s ease,
          transform 0.6s ease;
      }
      .reveal.in {
        opacity: 1;
        transform: none;
      }

      .site-footer {
        max-width: 1080px;
        margin: 0 auto;
        padding: 2rem 1.5rem 3rem;
        border-top: 1px solid #18243a;
        color: #8f9bb0;
        font-size: 0.9rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: space-between;
        align-items: center;
      }
      .site-footer nav a {
        color: #c2cad8;
        text-decoration: none;
        margin-left: 1.25rem;
      }
      @media (max-width: 600px) {
        .site-footer {
          flex-direction: column;
          align-items: flex-start;
        }
        .site-footer nav a {
          margin: 0 1.25rem 0 0;
        }

        /* Scene: give the canvas more vertical room and make the HUD compact
           so the controls don't crowd the 3D view on small screens. */
        .scene-canvas {
          height: clamp(320px, 64vh, 460px);
        }
        .scene-hud {
          padding: 0.7rem 0.8rem 0.85rem;
          gap: 0.5rem;
        }
        .phase-track {
          gap: 0.3rem;
        }
        .phase-chip {
          font-size: 0.68rem;
          padding: 0.25rem 0.6rem;
        }
        .phase-caption {
          font-size: 0.82rem;
          min-height: 3.6em;
        }
        .board-toggle {
          font-size: 0.8rem;
          padding: 0.45rem 0.8rem;
        }
        .scene-head {
          margin-bottom: 1rem;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        :global(html) {
          scroll-behavior: auto;
        }
        .reveal {
          opacity: 1;
          transform: none;
          transition: none;
        }
        .btn:hover,
        .card:hover {
          transform: none;
        }
      }
    </style>
  </body>
</html>
