        position: relative;
        padding-left: 1.6rem;
        color: #c2cad8;
      }
      .see li::before {
        position: absolute;
        left: 0;
        top: 0;
        font-weight: 700;
      }
      .cannot {
        border-color: #1d4a44;
      }
      .cannot h3 {
        color: #aef6ec;
      }
      .cannot li::before {
        content: "✕";
        color: #38e0d0;
      }
      .can {
        border-color: #4a3f1d;
      }
      .can h3 {
        color: #f2d98f;
      }
      .can li::before {
        content: "●";
        color: #d8a93a;
        font-size: 0.7em;
        top: 0.2em;
      }

      /* ---- Comparison table ---- */
      .cmp-scroll {
        overflow-x: auto;
        margin-top: 1.75rem;
        border-radius: 14px;
        border: 1px solid #1e1c3c;
      }
      .cmp-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 520px;
        font-size: 0.97rem;
      }
      .cmp-table th,
      .cmp-table td {
        text-align: left;
        padding: 0.85rem 1.1rem;
        border-bottom: 1px solid #1a1830;
      }
      .cmp-table thead th {
        font-family: var(--orp-display);
        color: #d7d0ff;
        font-size: 1rem;
        background: #11132b;
      }
      .cmp-table tbody th {
        color: #e3e9f2;
        font-weight: 600;
      }
      .cmp-table td {
        color: #c2cad8;
      }
      .cmp-table td.good {
        color: #8ee9da;
      }
      .cmp-table td.bad {
        color: #f0a3a3;
      }
      .cmp-table td.meh {
        color: #e8c98a;
      }
      .cmp-table tbody tr:last-child th,
      .cmp-table tbody tr:last-child td {
        border-bottom: none;
      }

      /* ---- Threat ---- */
      .threat {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        margin-top: 1.75rem;
      }
      .threat h3 {
        font-size: 1.15rem;
        margin: 0 0 0.75rem;
      }
      .t-protect {
        color: #8ee9da;
      }
      .t-limit {
        color: #e8c98a;
      }
      .threat p {
        color: #c2cad8;
        margin: 0;
      }
      .tradeoff-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 1rem;
      }
      .tradeoff-list li {
        padding: 0.4rem 0 0.4rem 1.25rem;
        border-left: 3px solid #2f74e6;
        color: #c2cad8;
      }
      .tradeoff-list strong {
        color: #f4f7fc;
      }

      /* ---- Code blocks ---- */
      .gs {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1.25rem;
        margin-top: 1.75rem;
      }
      .code-block {
        margin: 1.75rem 0 0;
        border: 1px solid #221f42;
        border-radius: 12px;
        overflow: hidden;
        background: #0b0d1c;
      }
      .gs .code-block {
        margin-top: 0;
      }
      .code-block figcaption {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.55rem 0.9rem;
        background: #11132b;
        border-bottom: 1px solid #221f42;
        font-size: 0.82rem;
        color: #9aa6bd;
      }
      .copy-btn {
        font: inherit;
        font-size: 0.78rem;
        font-weight: 600;
        color: #c2cad8;
        background: rgba(18, 28, 46, 0.85);
        border: 1px solid #2a3a58;
        border-radius: 7px;
        padding: 0.25rem 0.7rem;
        cursor: pointer;
        transition: all 0.16s ease;
      }
      .copy-btn:hover {
        border-color: #38e0d0;
        color: #aef6ec;
      }
      .copy-btn.copied {
        border-color: #38e0d0;
        color: #aef6ec;
      }
      .code-block pre {
        margin: 0;
        padding: 1.1rem 1.2rem;
        overflow-x: auto;
        font-size: 0.9rem;
        line-height: 1.7;
      }
      .code-block code {
        font-family: ui-monospace, "SF Mono", "Cascadia Code", Menlo, Consolas,
          monospace;
        color: #e3e9f2;
      }
      .code-block .cmt {
        color: #6f7a90;
      }
      .code-block .kw {
        color: #9a7bff;
      }
      .code-block .str {
        color: #8ee9da;
      }
      .gs-note {
        margin-top: 1.25rem;
        font-size: 0.9rem;
        color: #9aa6bd;
        max-width: 760px;
      }

      /* ---- FAQ ---- */
      .faq {
        margin-top: 1.75rem;
        display: grid;
        gap: 0.75rem;
        max-width: 820px;
      }
      .faq-item {
        border: 1px solid #1e1c3c;
        border-radius: 12px;
        background: linear-gradient(180deg, #11132b 0%, #0a0c1a 100%);
        overflow: hidden;
      }
      .faq-item summary {
        cursor: pointer;
        padding: 1rem 1.25rem;
        font-weight: 600;
        color: #f4f7fc;
        font-size: 1.02rem;
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }
      .faq-item summary::-webkit-details-marker {
        display: none;
      }
      .faq-item summary::after {
        content: "+";
        color: #9a7bff;
        font-size: 1.3rem;
        line-height: 1;
        transition: transform 0.2s ease;
      }
      .faq-item[open] summary::after {
        transform: rotate(45deg);
      }
      .faq-a {
        padding: 0 1.25rem 1.15rem;
      }
      .faq-a p {
        margin: 0 0 0.5rem;
        color: #c2cad8;
      }
      .faq-a .inline-link {
        margin-top: 0;
        font-size: 0.92rem;
      }

      .final-cta {
        text-align: center;
        padding: 4.5rem 0;
      }
      .final-lede {
        margin: 0.75rem auto 0;
      }
      .final-cta .cta-row {
        justify-content: center;
        margin-top: 1.75rem;
      }

      /* ---- Reveal animation ---- */
      .reveal {
        opacity: 0;
        transform: translateY(24px);
        transition:
          opacity 0.6s ease,
          transform 0.6s ease;
      }
      .reveal.in {
        opacity: 1;
        transform: none;
      }

      .site-footer {
        max-width: 1080px;
        margin: 0 auto;
        padding: 2rem 1.5rem 3rem;
        border-top: 1px solid #18243a;
        color: #8f9bb0;
        font-size: 0.9rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: space-between;
        align-items: center;
      }
      .site-footer nav a {
        color: #c2cad8;
        text-decoration: none;
        margin-left: 1.25rem;
      }
      @media (max-width: 600px) {
        .site-footer {
          flex-direction: column;
          align-items: flex-start;
        }
        .site-footer nav {
          display: flex;
          flex-wrap: wrap;
          gap: 0.5rem 0;
        }
        .site-footer nav a {
          margin: 0 1.25rem 0 0;
        }

        /* Scene: restack the HUD below the canvas so controls don't overlay the
           3D view on small screens. */
        .scene-canvas {
          height: clamp(300px, 52vh, 420px);
        }
        .scene-hud {
          position: static;
          background: #0b0d1c;
          border-top: 1px solid #221f42;
          padding: 0.85rem 0.9rem 1rem;
        }
        .phase-chip {
          font-size: 0.72rem;
          padding: 0.35rem 0.7rem;
        }
        .phase-caption {
          font-size: 0.85rem;
          min-height: 3.6em;
        }
        .board-toggle {
          font-size: 0.82rem;
          padding: 0.55rem 0.85rem;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        :global(html) {
          scroll-behavior: auto;
        }
        .reveal {
          opacity: 1;
          transform: none;
          transition: none;
        }
        .btn:hover,
        .card:hover {
          transform: none;
        }
      }
    </style>
  </body>
</html>
