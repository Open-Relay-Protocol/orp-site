    <script>
      import { initOrpScene } from "../scripts/orp-scene.js";
      import { initOrpBackground } from "../scripts/orp-bg.js";

      // Atmospheric Three.js backdrop (falls back to the CSS sky gradient).
      const bgEl = document.getElementById("orp-bg");
      if (bgEl) {
        try {
          initOrpBackground(bgEl);
        } catch (e) {
          /* CSS gradient remains */
        }
      }

      const PHASES = [
        {
          caption:
            "Both devices already hold one shared key bound to one target. They announce presence as opaque tags.",
        },
        {
          caption:
            "Device A's WebRTC offer (SDP/ICE) is sealed, then relayed through the board. The board forwards bytes it cannot open.",
        },
        {
          caption:
            "Device B seals its answer and sends it back. Same blind relay: the board routes on the tag, never the contents.",
        },
        {
          caption:
            "The peers open a direct channel. The board brokered the meeting and is now blind to the conversation entirely.",
        },
      ];

      const container = document.getElementById("orp-scene");
      const fallback = document.getElementById("scene-fallback");
      const hud = document.querySelector("[data-hud]");
      const caption = document.querySelector("[data-caption]");
      const boardToggle = document.querySelector("[data-board-toggle]");
      const boardNote = document.querySelector("[data-board-note]");
      const chips = Array.from(document.querySelectorAll(".phase-chip"));

      let scene = null;
      try {
        scene = initOrpScene(container, {
          onPhase(i) {
            chips.forEach((c, idx) =>
              c.setAttribute("aria-selected", idx === i ? "true" : "false"),
            );
            if (caption) caption.textContent = PHASES[i]?.caption ?? "";
          },
          onBoardView(on) {
            boardToggle?.setAttribute("aria-pressed", on ? "true" : "false");
            const t = boardToggle?.querySelector(".toggle-text");
            if (t) t.textContent = on ? "Showing the board's view" : "See the board's view";
            if (boardNote) boardNote.hidden = !on;
            hud?.classList.toggle("is-board", on);
          },
        });
      } catch (e) {
        scene = null;
      }

      if (scene) {
        fallback?.setAttribute("hidden", "");
        hud?.removeAttribute("hidden");
        chips.forEach((chip) =>
          chip.addEventListener("click", () =>
            scene.goToPhase(Number(chip.dataset.phase)),
          ),
        );
        boardToggle?.addEventListener("click", () =>
          scene.setBoardView(!scene.isBoardView()),
        );
      }

      // Copy-to-clipboard for code blocks (progressive enhancement).
      document.querySelectorAll(".copy-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(btn.dataset.copy ?? "");
            const prev = btn.textContent;
            btn.textContent = "Copied";
            btn.classList.add("copied");
            setTimeout(() => {
              btn.textContent = prev;
              btn.classList.remove("copied");
            }, 1600);
          } catch (e) {
            /* clipboard unavailable; text is still selectable */
          }
        });
      });

      // Scroll reveal for sections.
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const reveals = document.querySelectorAll(".reveal");
      if (reduce || !("IntersectionObserver" in window)) {
        reveals.forEach((el) => el.classList.add("in"));
      } else {
        const obs = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("in");
                obs.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        reveals.forEach((el) => obs.observe(el));
      }
    </script>

