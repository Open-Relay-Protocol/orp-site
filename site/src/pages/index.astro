---
import "../styles/custom.css";

const GITHUB_URL = "https://github.com/Open-Relay-Protocol/orp";
const GITHUB_SLUG = "Open-Relay-Protocol/orp"; // for shields.io live badges
// NOTE: TEST_COUNT is unverified against the upstream repo (see OPEN-QUESTIONS.md).
// Confirm before trusting the exact number; the surrounding copy describes what
// the tests prove, which holds regardless of the count.
const TEST_COUNT = 146;

const site = Astro.site ?? new URL("https://www.openrelayprotocol.com");
const base = import.meta.env.BASE_URL; // includes trailing slash
const href = (p) => base + p.replace(/^\//, "");
const canonical = new URL(base, site).href;
const ogImage = new URL(href("/og/orp-og.png"), site).href;

const title = "ORP — Secure WebRTC Signaling Protocol (Blind Rendezvous)";
const description =
  "ORP is an open, privacy-preserving WebRTC signaling protocol. The rendezvous server is structurally unable to read your messages, keys, or signaling.";

// shields.io live badges: render real-time GitHub metrics, degrade to alt text.
const badge = (path, label, alt) => ({
  src: `https://img.shields.io/${path}?style=flat-square&labelColor=0b0c1a&color=5b3fd6`,
  alt,
  label,
});
// Static badge for facts GitHub can't derive from a single SPDX file. The repo
// ships a split license (Apache-2.0 core/client/spec/tests, AGPL-3.0 board), so
// the live github/license badge reports "not identifiable"; state it directly.
const staticBadge = (message, alt) => ({
  src: `https://img.shields.io/badge/license-${message}-5b3fd6?style=flat-square&labelColor=0b0c1a`,
  alt,
  label: "license",
});
const badges = [
  badge(`github/stars/${GITHUB_SLUG}`, "stars", "GitHub stars"),
  badge(`github/contributors/${GITHUB_SLUG}`, "contributors", "GitHub contributors"),
  badge(`github/last-commit/${GITHUB_SLUG}`, "last commit", "Last commit"),
  staticBadge("Apache--2.0%20%2F%20AGPL--3.0", "License: Apache-2.0 / AGPL-3.0"),
  badge(`github/languages/top/${GITHUB_SLUG}`, "language", "Primary language"),
];

const faqs = [
  {
    q: "Can the server read my messages?",
    a: "No. The rendezvous server is structurally blind: message contents, private keys, and unsealed signaling never reach it in readable form. It sees only opaque tags and sealed payloads it cannot open. This is enforced by the wire format, not by a logging policy.",
    href: "/docs/blindness/",
  },
  {
    q: "Does ORP have forward secrecy?",
    a: "No. The inner message layer is static and does not rekey per message, so a future key compromise can expose past sealed payloads. This is a stated trade-off, documented in the threat model.",
    href: "/docs/threat-model/",
  },
  {
    q: "Can the server see who I talk to?",
    a: "It can observe that two endpoints rendezvous, which is the visible social graph. It cannot read what they exchange. ORP does not claim full anonymity.",
    href: "/docs/threat-model/",
  },
  {
    q: "How is this different from Signal's model?",
    a: "ORP targets the rendezvous and signaling layer and makes the server structurally unable to read signaling, keys, or contents, as an invariant of the wire format. It does not provide forward secrecy and it does not hide the social graph, both of which it states plainly. It is signaling infrastructure, not a full messenger.",
    href: "/compare/",
  },
  {
    q: "Is the board really stateless?",
    a: "The board exposes a single stateful channel and holds only the routing state it needs to broker a meeting. It does not hold readable message contents or keys.",
    href: "/docs/protocol/",
  },
  {
    q: "What happens if a key is compromised?",
    a: "Because there is no forward secrecy, a compromised key can expose past sealed payloads encrypted under it. A key is bound to one target, so the exposure is scoped to that target rather than a whole directory. Identity rotation (ORP-004) limits the lifetime of an identity key.",
    href: "/docs/identity-rotation/",
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "ORP",
    url: site.href,
    description,
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    name: "ORP (Open Relay Protocol)",
    description,
    url: canonical,
    codeRepository: GITHUB_URL,
    programmingLanguage: "TypeScript",
    author: { "@type": "Organization", name: "Prograde Solutions" },
    license: "https://www.apache.org/licenses/LICENSE-2.0",
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Prograde Solutions",
    url: site.href,
    logo: ogImage,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={href("/favicon.svg")} type="image/svg+xml" />
    <meta name="theme-color" content="#0E1726" />

    <!-- Share Tech: the official ORP display/brand typeface. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Share+Tech&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="ORP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="ORP. The rendezvous server is structurally blind."
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link
      rel="preload"
      as="image"
      href={href("/favicon.svg")}
      type="image/svg+xml"
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
      is:inline
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <div id="orp-bg" class="bg-scene" aria-hidden="true"></div>

    <header class="site-header">
      <a class="brand" href={base} aria-label="Open Relay Protocol home">
        <img
          class="brand-mark"
          src={href("/logos/orp-logo-white.png")}
          alt="Open Relay Protocol"
          width="40"
          height="40"
        />
      </a>
      <nav class="site-nav" aria-label="Primary">
        <a href={href("#how-it-works")}>How it works</a>
        <a href={href("/compare/")}>Compare</a>
        <a href={href("/docs/overview/")}>Docs</a>
        <a class="nav-cta" href={GITHUB_URL} rel="noopener">
          <svg class="gh-icon" viewBox="0 0 16 16" aria-hidden="true" width="16" height="16"
            ><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
            ></path></svg
          >
          <span>GitHub</span>
          <img
            class="nav-stars"
            src={`https://img.shields.io/github/stars/${GITHUB_SLUG}?style=flat-square&label=&labelColor=0b0c1a&color=2a3548`}
            alt="GitHub stars"
            width="44"
            height="20"
            loading="lazy"
          />
        </a>
      </nav>
    </header>

    <main id="main">
      <!-- 1. HERO -->
      <section class="hero">
        <p class="eyebrow">
          Open Relay Protocol · Apache-2.0 core, AGPL-3.0 board
        </p>
        <h1>
          Secure WebRTC signaling whose server
          <span class="grad">can't read your signaling.</span>
        </h1>
        <p class="lede">
          ORP is an open, privacy-preserving rendezvous protocol for
          peer-to-peer and WebRTC apps. Two devices meet through a server that
          is <strong>structurally</strong> unable to read your messages, keys,
          or signaling — an enforced wire-format invariant, not a no-log promise.
        </p>
        <div class="cta-row">
          <a class="btn btn-github" href={GITHUB_URL} rel="noopener">
            <svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18"
              ><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              ></path></svg
            >
            Star on GitHub
          </a>
          <a class="btn btn-ghost" href={href("/docs/overview/")}>
            Read the docs →
          </a>
        </div>

        <!-- GitHub trust strip (live shields.io badges) -->
        <div class="trust-strip" aria-label="Project metrics from GitHub">
          {
            badges.map((b) => (
              <img
                class="badge"
                src={b.src}
                alt={b.alt}
                height="20"
                loading="lazy"
              />
            ))
          }
        </div>

        <!-- Compact architecture visualization -->
        <figure class="arch-viz">
          <svg
            viewBox="0 0 720 150"
            role="img"
            aria-labelledby="arch-title arch-desc"
          >
            <title id="arch-title">ORP blind-board architecture</title>
            <desc id="arch-desc"
              >Device A and Device B each connect to a blind board. They send
              opaque presence tags and sealed offer and answer payloads. The
              board routes by tag but cannot read the sealed contents.</desc
            >
            <g fill="none" stroke-width="2">
              <rect x="20" y="50" width="150" height="56" rx="12" stroke="#2f74e6"></rect>
              <rect x="285" y="50" width="150" height="56" rx="12" stroke="#9a7bff"></rect>
              <rect x="550" y="50" width="150" height="56" rx="12" stroke="#2f74e6"></rect>
            </g>
            <g fill="#f4f7fc" font-family="'Share Tech', 'Segoe UI', system-ui, sans-serif" font-size="18" text-anchor="middle">
              <text x="95" y="84">Device A</text>
              <text x="360" y="78">Blind board</text>
              <text x="625" y="84">Device B</text>
            </g>
            <g fill="#9a7bff" font-family="sans-serif" font-size="11" text-anchor="middle">
              <text x="360" y="96">routes opaque tags</text>
            </g>
            <g fill="#8f9bb0" font-family="sans-serif" font-size="12" text-anchor="middle">
              <text x="227" y="38">sealed offer</text>
              <text x="493" y="38">sealed answer</text>
            </g>
            <g stroke="#5b6678" stroke-width="2" marker-end="url(#arrowh)">
              <line x1="170" y1="78" x2="283" y2="78"></line>
              <line x1="435" y1="78" x2="548" y2="78"></line>
            </g>
            <defs>
              <marker id="arrowh" viewBox="0 0 10 10" refX="8" refY="5"
                markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" fill="#5b6678"></path>
              </marker>
            </defs>
          </svg>
          <figcaption>
            Device A → <strong>Blind board</strong> → Device B. The board routes
            opaque tags and forwards sealed payloads it cannot open.
          </figcaption>
        </figure>
      </section>

      <!-- 2. HOW ORP WORKS -->
      <section id="how-it-works" class="reveal" aria-labelledby="how-h">
        <p class="sec-eyebrow">01 — How it works</p>
        <h2 id="how-h">How ORP works</h2>
        <p class="section-lede">
          ORP brokers a meeting between two devices that already share one key
          bound to one rendezvous target. The exchange runs in three sealed
          phases; the board only ever sees routing tags.
        </p>
        <div class="cards steps">
          <article class="card step">
            <span class="card-num">KEY</span>
            <h3>Both devices hold one key</h3>
            <p>
              A shared key is bound to one target. Devices announce presence as
              opaque tags. The board learns <em>that</em> someone is present, never
              <em>who</em> or <em>what</em>.
            </p>
          </article>
          <article class="card step">
            <span class="card-num">OFFER</span>
            <h3>Sealed WebRTC offer</h3>
            <p>
              The initiating peer seals its WebRTC offer (SDP/ICE) and relays it
              through the board. The board forwards bytes it cannot open.
            </p>
          </article>
          <article class="card step">
            <span class="card-num">ANSWER</span>
            <h3>Sealed answer, then connected</h3>
            <p>
              The responder seals its answer back the same way. The peers open a
              direct channel; the board is now blind to the conversation
              entirely.
            </p>
          </article>
        </div>
        <a class="inline-link" href={href("/docs/protocol/")}
          >Read the wire types and phases →</a
        >
      </section>

      <!-- 3. WHAT THE SERVER CAN AND CANNOT SEE -->
      <section class="reveal" aria-labelledby="sees-h">
        <p class="sec-eyebrow">02 — Metadata exposure</p>
        <h2 id="sees-h">What the server can and cannot see</h2>
        <p class="section-lede">
          Blindness is enforced by the wire format. There is no frame shape that
          carries plaintext the board could read, so the property holds even if
          the operator is hostile, compromised, or compelled.
        </p>
        <div class="seesplit">
          <div class="see cannot">
            <h3>The board cannot see</h3>
            <ul>
              <li>Message contents</li>
              <li>Private keys</li>
              <li>Unsealed signaling (SDP / ICE)</li>
              <li>Who you are — only opaque tags</li>
            </ul>
          </div>
          <div class="see can">
            <h3>The board can see</h3>
            <ul>
              <li>That two endpoints rendezvous (the social graph)</li>
              <li>Opaque presence and routing tags</li>
              <li>The <code>frame_kind</code> routing tag</li>
              <li>Sealed payloads it cannot open</li>
            </ul>
          </div>
        </div>
        <a class="inline-link" href={href("/docs/blindness/")}
          >Read the blindness invariant →</a
        >
      </section>

      <!-- 4. INTERACTIVE DEMO -->
      <section id="demo" class="scene-section reveal" aria-labelledby="scene-h">
        <div class="scene-head">
          <p class="sec-eyebrow">03 — Interactive demo</p>
          <h2 id="scene-h">See a rendezvous happen</h2>
          <p class="section-lede">
            Two devices share one key bound to one target and relay sealed
            payloads through the board. Drag to orbit, step through the phases,
            then flip to <em>the board's view</em> and watch everything it cannot
            read collapse to opaque tags.
          </p>
        </div>

        <div class="scene-wrap">
          <div id="orp-scene" class="scene-canvas" role="img"
            aria-label="3D animation of two devices exchanging sealed payloads through a blind rendezvous board.">
            <svg
              id="scene-fallback"
              class="diagram"
              viewBox="0 0 720 240"
              role="img"
              aria-labelledby="diagram-title diagram-desc"
            >
              <title id="diagram-title">ORP blind broker data flow</title>
              <desc id="diagram-desc"
                >Device A and Device B each connect to the board. They send
                opaque presence tags and sealed offer and answer payloads. The
                board routes by tag but cannot read the sealed contents.</desc
              >
              <g fill="none" stroke="#2f74e6" stroke-width="2">
                <rect x="20" y="90" width="150" height="60" rx="10"></rect>
                <rect x="285" y="90" width="150" height="60" rx="10"></rect>
                <rect x="550" y="90" width="150" height="60" rx="10"></rect>
              </g>
              <g fill="#f4f7fc" font-family="'Share Tech', 'Segoe UI', system-ui, sans-serif" font-size="18"
                text-anchor="middle">
                <text x="95" y="125">Device A</text>
                <text x="360" y="118">Blind board</text>
                <text x="625" y="125">Device B</text>
              </g>
              <g fill="#8f9bb0" font-family="sans-serif" font-size="12"
                text-anchor="middle">
                <text x="360" y="138">routes opaque tags</text>
                <text x="227" y="80">sealed offer</text>
                <text x="493" y="80">sealed answer</text>
              </g>
              <g stroke="#5b6678" stroke-width="2" marker-end="url(#arrow)">
                <line x1="170" y1="120" x2="283" y2="120"></line>
                <line x1="435" y1="120" x2="548" y2="120"></line>
              </g>
              <defs>
                <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5"
                  markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                  <path d="M0,0 L10,5 L0,10 z" fill="#5b6678"></path>
                </marker>
              </defs>
            </svg>
          </div>

          <div class="scene-hud" data-hud hidden>
            <div class="phase-track" role="tablist" aria-label="Rendezvous phases">
              <button class="phase-chip" data-phase="0" role="tab">KEY</button>
              <button class="phase-chip" data-phase="1" role="tab">OFFER</button>
              <button class="phase-chip" data-phase="2" role="tab">ANSWER</button>
              <button class="phase-chip" data-phase="3" role="tab">CONNECTED</button>
            </div>
            <p class="phase-caption" data-caption aria-live="polite"></p>
            <button class="board-toggle" data-board-toggle aria-pressed="false">
              <span class="dot"></span>
              <span class="toggle-text">See the board's view</span>
            </button>
          </div>
        </div>

        <p class="scene-note" data-board-note hidden>
          In the board's view, device identities reduce to opaque tags and every
          payload reads <code>SEALED</code>. The only thing the board reads is
          the <code>frame_kind</code> routing tag — exactly the
          <a href={href("/docs/blindness/")}>collision-table</a> observables, nothing more.
        </p>
      </section>

      <!-- 5. COMPARISON -->
      <section class="reveal" aria-labelledby="cmp-h">
        <p class="sec-eyebrow">04 — Comparison</p>
        <h2 id="cmp-h">ORP vs a traditional signaling server</h2>
        <p class="section-lede">
          A conventional signaling server reads the introduction even when the
          call is end-to-end encrypted. ORP removes that trust from the path.
        </p>
        <div class="cmp-scroll">
          <table class="cmp-table">
            <thead>
              <tr>
                <th scope="col"></th>
                <th scope="col">Traditional signaling server</th>
                <th scope="col">ORP blind board</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">Reads SDP / ICE</th>
                <td class="bad">Yes</td>
                <td class="good">No, sealed</td>
              </tr>
              <tr>
                <th scope="row">Reads keys</th>
                <td class="bad">Often</td>
                <td class="good">No</td>
              </tr>
              <tr>
                <th scope="row">Sees social graph</th>
                <td class="bad">Yes</td>
                <td class="meh">Yes (stated)</td>
              </tr>
              <tr>
                <th scope="row">Guarantee type</th>
                <td class="bad">Policy (no-log promise)</td>
                <td class="good">Invariant (wire format)</td>
              </tr>
              <tr>
                <th scope="row">Externally verifiable</th>
                <td class="bad">No</td>
                <td class="good">Yes, via the test suite</td>
              </tr>
            </tbody>
          </table>
        </div>
        <a class="inline-link" href={href("/compare/")}
          >Full comparison: blind rendezvous vs trusted signaling servers →</a
        >
      </section>

      <!-- 6. THREAT MODEL SUMMARY -->
      <section class="reveal" aria-labelledby="threat-h">
        <p class="sec-eyebrow">05 — Threat model</p>
        <h2 id="threat-h">What ORP protects, and what it does not</h2>
        <div class="threat">
          <div>
            <h3 class="t-protect">Protects against</h3>
            <p>
              A hostile, compromised, or compelled board reading your contents,
              keys, or signaling. The guarantee lives in the wire format, so it
              does not depend on the operator's conscience.
            </p>
          </div>
          <div>
            <h3 class="t-limit">Stated limits, up front</h3>
            <ul class="tradeoff-list">
              <li>
                <strong>No forward secrecy.</strong> The inner message layer is
                static, so a key compromise can expose past sealed payloads.
              </li>
              <li>
                <strong>The social graph is visible.</strong> The board can see
                that two endpoints meet. This is not 100% anonymity, and we do
                not claim it.
              </li>
              <li>
                <strong>Replay and linkability bounds.</strong> Presence tags
                carry documented limits, with scoped mitigations rather than
                absolute guarantees.
              </li>
            </ul>
          </div>
        </div>
        <a class="inline-link" href={href("/docs/threat-model/")}
          >Read the full threat model →</a
        >
      </section>

      <!-- 7. TEST SUITE EVIDENCE -->
      <section class="reveal" aria-labelledby="evidence-h">
        <p class="sec-eyebrow">06 — Evidence</p>
        <h2 id="evidence-h">The proof is in the test suite</h2>
        <p class="section-lede">
          The guarantee isn't a promise; it's checked by an adversarial suite you
          can run yourself.
        </p>
        <div class="cards">
          <article class="card">
            <h3>Adversarial tests</h3>
            <p>
              The suite is written to <em>attack</em> the invariant, with a
              per-test note of exactly what each one proves.
            </p>
          </article>
          <article class="card">
            <h3>Board-view scan</h3>
            <p>
              Asserts that everything the board can observe is limited to opaque
              tags and sealed payloads it cannot open.
            </p>
          </article>
          <article class="card">
            <h3>Wire-byte scan</h3>
            <p>
              Inspects raw datagram bytes on the wire to confirm no plaintext
              contents, keys, or unsealed signaling leak.
            </p>
          </article>
        </div>
        <figure class="code-block">
          <figcaption>
            <span>Run the suite</span>
